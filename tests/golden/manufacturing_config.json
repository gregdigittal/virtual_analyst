        "expression": "units_produced * price_per_unit",
        "inputs": ["n_units_produced", "drv:price_per_unit"]
      },
      {
        "formula_id": "f_material_cogs",
        "output_node_id": "n_material_cogs",
        "expression": "units_produced * material_cost",
        "inputs": ["n_units_produced", "drv:material_cost"]
