# Copy this file to .env and fill in actual values.

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finmodel_dev

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
# Optional: JWT secret (Project Settings → API → JWT Secret) so API can verify Bearer tokens and set tenant/user from token
SUPABASE_JWT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# LLM Providers — set to real keys for draft_assumptions, memo generation, Excel classification, etc.
# Leave empty to disable that provider (router will use the other or fail if both missing).
# Get keys: Anthropic https://console.anthropic.com/ → API Keys
#           OpenAI   https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Claude Agent SDK — set AGENT_SDK_ENABLED=true to activate agent-powered LLM tasks.
AGENT_SDK_ENABLED=true
AGENT_SDK_DEFAULT_MODEL=sonnet
AGENT_SDK_MAX_TURNS=15
AGENT_SDK_MAX_BUDGET_USD=0.50
AGENT_EXCEL_INGESTION_ENABLED=true
AGENT_DRAFT_CHAT_ENABLED=true
AGENT_BUDGET_NL_QUERY_ENABLED=true
AGENT_REFORECAST_ENABLED=true

# Security
JWT_SECRET=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=false

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT=100/minute
# Optional: secret for cron endpoints (e.g. deadline-reminders). Set X-Cron-Secret header when calling.
CRON_SECRET=

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Production: set to your app URL (e.g. https://yourapp.com) so SSO/email links redirect correctly
# NEXT_PUBLIC_APP_URL=https://yourapp.com
