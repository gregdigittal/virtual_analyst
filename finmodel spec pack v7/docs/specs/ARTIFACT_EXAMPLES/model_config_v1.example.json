      { "from": "n_utilization", "to": "n_units_produced" },
      { "from": "n_yield", "to": "n_units_produced" },
      { "from": "n_units_produced", "to": "n_revenue" },
      { "from": "n_price", "to": "n_revenue" },
      { "from": "n_units_produced", "to": "n_material_cogs" },
      { "from": "n_material", "to": "n_material_cogs" }
    ],
    "formulas": [
