        "formula_id": "f_units",
        "output_node_id": "n_units_produced",
        "expression": "capacity * utilization * yield_rate",
        "inputs": ["n_capacity", "n_utilization", "n_yield"],
        "notes": "Effective monthly production"
      },
      {
        "formula_id": "f_revenue",
        "output_node_id": "n_revenue",
        "expression": "units * price",
        "inputs": ["n_units_produced", "n_price"],
        "notes": "Monthly revenue = units produced × selling price"
      },
      {
        "formula_id": "f_material_cogs",
        "output_node_id": "n_material_cogs",
        "expression": "units * material_cost",
        "inputs": ["n_units_produced", "n_material"],
        "notes": "Material COGS = units produced × material cost per unit"
      }
    ]
