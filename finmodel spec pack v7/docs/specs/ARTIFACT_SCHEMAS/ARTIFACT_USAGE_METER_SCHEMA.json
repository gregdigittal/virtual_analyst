{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finmodel.app/schemas/usage_meter_v1.json",
  "title": "usage_meter_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "tenant_id",
    "period",
    "usage",
    "costs",
    "integrity"
  ],
  "properties": {
    "artifact_type": { "const": "usage_meter_v1" },
    "artifact_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tenant_id": { "type": "string" },
    "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$", "description": "Billing period (YYYY-MM)" },
    "updated_at": { "type": "string", "format": "date-time" },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["llm_calls", "llm_tokens_total"],
      "properties": {
        "llm_calls": { "type": "integer", "minimum": 0 },
        "llm_tokens_total": { "type": "integer", "minimum": 0 },
        "llm_tokens_by_provider": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anthropic": { "type": "integer", "minimum": 0 },
            "openai": { "type": "integer", "minimum": 0 }
          }
        },
        "llm_tokens_by_task": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 },
          "description": "Token counts keyed by task_label"
        },
        "mc_runs": { "type": "integer", "minimum": 0 },
        "mc_simulations_total": { "type": "integer", "minimum": 0 },
        "sync_events": { "type": "integer", "minimum": 0 },
        "memo_pages": { "type": "integer", "minimum": 0 },
        "storage_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "costs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency"],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "llm_estimated_cents": { "type": "integer", "minimum": 0, "description": "Estimated LLM cost in cents" },
        "llm_by_provider": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "anthropic_cents": { "type": "integer", "minimum": 0 },
            "openai_cents": { "type": "integer", "minimum": 0 }
          }
        },
        "overage_cents": { "type": "integer", "minimum": 0, "description": "Overage charges in cents" }
      }
    },
    "integrity": { "$ref": "#/$defs/integrity_block" }
  },
  "$defs": {
    "integrity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks"],
      "properties": {
        "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
        "checks": { "type": "array", "items": { "$ref": "#/$defs/integrity_check" } }
      }
    },
    "integrity_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "severity", "message"],
      "properties": {
        "check_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "maxLength": 1000 },
        "details": { "type": "object" }
      }
    }
  }
}
