{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finmodel.app/schemas/canonical_sync_snapshot_v1.json",
  "title": "canonical_sync_snapshot_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "tenant_id",
    "snapshot_id",
    "connection_id",
    "as_of",
    "canonical",
    "integrity"
  ],
  "properties": {
    "artifact_type": { "const": "canonical_sync_snapshot_v1" },
    "artifact_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tenant_id": { "type": "string" },
    "snapshot_id": { "type": "string" },
    "connection_id": { "type": "string" },
    "as_of": { "type": "string", "format": "date-time" },
    "provider": { "type": "string", "enum": ["xero", "quickbooks", "sage", "manual"] },
    "period_start": { "type": "string", "format": "date" },
    "period_end": { "type": "string", "format": "date" },
    "canonical": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "accounts"],
      "properties": {
        "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "org_name": { "type": ["string", "null"] },
        "accounts": {
          "type": "array",
          "items": { "$ref": "#/$defs/canonical_account" }
        },
        "trial_balance": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/trial_balance_line" }
        },
        "income_statement": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/statement_line" }
        },
        "balance_sheet": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/statement_line" }
        }
      }
    },
    "mapping_notes": {
      "type": ["array", "null"],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider_account_code": { "type": "string" },
          "provider_account_name": { "type": "string" },
          "canonical_type": { "type": "string" },
          "mapped": { "type": "boolean" },
          "notes": { "type": ["string", "null"] }
        }
      },
      "description": "Log of how provider accounts were mapped to canonical types"
    },
    "integrity": { "$ref": "#/$defs/integrity_block" }
  },
  "$defs": {
    "canonical_account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_code", "name", "account_type", "balance"],
      "properties": {
        "account_code": { "type": "string" },
        "name": { "type": "string" },
        "account_type": {
          "type": "string",
          "enum": ["revenue", "cogs", "operating_expense", "other_income", "other_expense", "tax", "current_asset", "fixed_asset", "current_liability", "long_term_liability", "equity"]
        },
        "sub_type": { "type": ["string", "null"] },
        "balance": { "type": "number", "description": "Balance in minor units (cents)" },
        "provider_account_code": { "type": ["string", "null"], "description": "Original account code from ERP" }
      }
    },
    "trial_balance_line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["account_code", "name", "debit", "credit"],
      "properties": {
        "account_code": { "type": "string" },
        "name": { "type": "string" },
        "debit": { "type": "number", "minimum": 0 },
        "credit": { "type": "number", "minimum": 0 }
      }
    },
    "statement_line": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "amount"],
      "properties": {
        "label": { "type": "string" },
        "section": { "type": ["string", "null"] },
        "amount": { "type": "number" },
        "is_total": { "type": "boolean", "default": false }
      }
    },
    "integrity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks"],
      "properties": {
        "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
        "checks": { "type": "array", "items": { "$ref": "#/$defs/integrity_check" } }
      }
    },
    "integrity_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "severity", "message"],
      "properties": {
        "check_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "maxLength": 1000 },
        "details": { "type": "object" }
      }
    }
  }
}
