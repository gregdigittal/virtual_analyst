{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finmodel.app/schemas/excel_sync_event_v1.json",
  "title": "excel_sync_event_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_type",
    "artifact_version",
    "tenant_id",
    "event_id",
    "excel_connection_id",
    "timestamp",
    "direction",
    "status",
    "diff",
    "integrity"
  ],
  "properties": {
    "artifact_type": { "const": "excel_sync_event_v1" },
    "artifact_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "tenant_id": { "type": "string" },
    "event_id": { "type": "string" },
    "excel_connection_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "direction": { "type": "string", "enum": ["pull", "push"] },
    "status": { "type": "string", "enum": ["succeeded", "failed", "partial"] },
    "initiated_by": { "type": ["string", "null"], "description": "user_id who triggered this sync" },
    "target": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "baseline_id": { "type": ["string", "null"] },
        "baseline_version": { "type": ["string", "null"] },
        "run_id": { "type": ["string", "null"] },
        "draft_session_id": { "type": ["string", "null"] },
        "changeset_id": { "type": ["string", "null"], "description": "Created changeset (for push events)" }
      }
    },
    "bindings_synced": { "type": "integer", "minimum": 0 },
    "diff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["changed", "errors"],
      "properties": {
        "changed": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["binding_id", "old", "new"],
            "properties": {
              "binding_id": { "type": "string" },
              "old": {},
              "new": {}
            }
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["binding_id", "message"],
            "properties": {
              "binding_id": { "type": "string" },
              "message": { "type": "string" },
              "error_type": { "type": ["string", "null"], "enum": ["type_mismatch", "out_of_range", "permission_denied", "not_found", null] }
            }
          }
        }
      }
    },
    "integrity": { "$ref": "#/$defs/integrity_block" }
  },
  "$defs": {
    "integrity_block": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "checks"],
      "properties": {
        "status": { "type": "string", "enum": ["passed", "warning", "failed"] },
        "checks": { "type": "array", "items": { "$ref": "#/$defs/integrity_check" } }
      }
    },
    "integrity_check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["check_id", "severity", "message"],
      "properties": {
        "check_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "maxLength": 1000 },
        "details": { "type": "object" }
      }
    }
  }
}
