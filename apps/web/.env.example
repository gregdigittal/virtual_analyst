# Virtual Analyst — Frontend Environment Variables
# Copy this file to .env.local and fill in values for local development.
# Never commit .env.local to source control.

# Supabase project credentials (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend API base URL (required)
# Local development: http://localhost:8000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Multi-tenancy enforcement (W6)
# Set to "true" once Supabase Auth is configured with an Auth Hook that injects
# tenant_id into app_metadata for all users. Until then, leave unset or "false".
# When "true", users without tenant_id in metadata are redirected to /login.
NEXT_PUBLIC_REQUIRE_TENANT_ID=false

# Optional: Remote log endpoint for structured error forwarding in production.
# POST application/json — receives LogEntry objects from apps/web/lib/logger.ts.
# Leave unset to write only to the browser console.
# Example: https://your-log-aggregator.com/ingest
NEXT_PUBLIC_LOG_ENDPOINT=
