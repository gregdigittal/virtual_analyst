# Set to "true" once Supabase Auth is configured with an Auth Hook that injects
# tenant_id into app_metadata for all users. Until then, leave unset or "false".
NEXT_PUBLIC_REQUIRE_TENANT_ID=false

# Optional: URL to POST structured log entries to in production.
# Format: POST application/json with LogEntry body (see apps/web/lib/logger.ts).
# Leave unset to only write to the browser console.
# Example: https://your-log-aggregator.com/ingest
NEXT_PUBLIC_LOG_ENDPOINT=

# Optional: Sentry DSN for frontend error tracking.
# Get from https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
